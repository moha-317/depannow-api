# ─── Serveur ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Base de données PostgreSQL ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=depannow
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── JWT ──────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# ─── CORS ─────────────────────────────────────────────────────
# '*' pour dev, mettre l'URL du frontend en prod
CORS_ORIGIN=*

# ─── Paiement (Stripe) — Sprint 5 ─────────────────────────────
# Clé secrète backend (NE JAMAIS exposer côté client)
STRIPE_SECRET_KEY=sk_test_...
# Secret webhook (obtenu via Stripe Dashboard ou CLI : stripe listen --print-secret)
STRIPE_WEBHOOK_SECRET=whsec_...
# Clé publique frontend (safe to expose)
STRIPE_PUBLISHABLE_KEY=pk_test_...
